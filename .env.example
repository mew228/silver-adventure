# ─────────────────────────────────────────
# Auth0 Token Vault / Application Settings
# ─────────────────────────────────────────

# Auth0 Domain (e.g., your-tenant.us.auth0.com)
AUTH0_DOMAIN=your-tenant.us.auth0.com

# Auth0 Client ID and Secret for the Bridgekeeper application
AUTH0_CLIENT_ID=your_auth0_client_id
AUTH0_CLIENT_SECRET=your_auth0_client_secret

# Auth0 Token Vault Audience (the API identifier for Token Vault)
AUTH0_AUDIENCE=https://your-tenant.us.auth0.com/api/v2/

# Auth0 Token Vault Management API Token (for vault operations)
AUTH0_MANAGEMENT_TOKEN=your_management_api_token

# Callback URL for OAuth flows
AUTH0_CALLBACK_URL=http://localhost:3000/callback

# ─────────────────────────────────────────
# Anthropic (for Local Intent Agent)
# ─────────────────────────────────────────

# Anthropic API Key for Claude claude-sonnet-4-20250514
ANTHROPIC_API_KEY=your_anthropic_api_key

# ─────────────────────────────────────────
# Mock Mode (set true to run without real credentials)
# ─────────────────────────────────────────

# Set to 'true' to use mock providers (no real API calls)
MOCK_PROVIDERS=true

# ─────────────────────────────────────────
# Server Configuration
# ─────────────────────────────────────────

PORT=3000
NODE_ENV=development

# ─────────────────────────────────────────
# Optional: Google OAuth Credentials
# ─────────────────────────────────────────

# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret

# ─────────────────────────────────────────
# Optional: GitHub OAuth Credentials
# ─────────────────────────────────────────

# GITHUB_CLIENT_ID=your_github_client_id
# GITHUB_CLIENT_SECRET=your_github_client_secret

# ─────────────────────────────────────────
# Optional: Slack OAuth Credentials
# ─────────────────────────────────────────

# SLACK_CLIENT_ID=your_slack_client_id
# SLACK_CLIENT_SECRET=your_slack_client_secret

# ─────────────────────────────────────────
# Optional: Notion OAuth Credentials
# ─────────────────────────────────────────

# NOTION_CLIENT_ID=your_notion_client_id
# NOTION_CLIENT_SECRET=your_notion_client_secret

# ─────────────────────────────────────────
# Optional: Jira OAuth Credentials
# ─────────────────────────────────────────

# JIRA_CLIENT_ID=your_jira_client_id
# JIRA_CLIENT_SECRET=your_jira_client_secret
# JIRA_CLOUD_ID=your_jira_cloud_instance_id
